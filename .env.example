# ========================================
# TravelLog 환경 변수 설정 파일 예시
# ========================================
# 이 파일을 복사해서 .env 파일로 만들고
# 실제 API 키를 입력하세요.
# .env 파일은 절대 Git에 업로드하지 마세요!
# ========================================

# -----------------------------------
# Firebase 설정
# Firebase 콘솔(https://console.firebase.google.com)에서
# 프로젝트 설정 > 앱 추가 > 웹 앱에서 확인할 수 있습니다
# -----------------------------------
VITE_FIREBASE_API_KEY=여기에_Firebase_API_키_입력
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456

# -----------------------------------
# Google Maps API 설정
# Google Cloud Console(https://console.cloud.google.com)에서
# Maps JavaScript API를 활성화하고 API 키를 생성하세요
# -----------------------------------
VITE_GOOGLE_MAPS_API_KEY=여기에_Google_Maps_API_키_입력
